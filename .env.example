# wenji environment template — copy to .env and fill in values.
# .env is git-ignored; .env.example is the only file that should be committed.
# DO NOT commit .env, DO NOT export these values into shell rc files.

# --- LLM query rewrite (optional) ---
# WENJI_LLM_BASE_URL=https://api.groq.com/openai/v1
# WENJI_LLM_API_KEY=
# WENJI_LLM_MODEL=llama-3.3-70b-versatile
# WENJI_LLM_TIMEOUT=10.0
# WENJI_LLM_REWRITE_CACHE_TTL_DAYS=30

# --- Entity / Intent sources (optional) ---
# WENJI_ENTITY_SOURCES=example:corpus-christian
# WENJI_INTENT_SOURCES=example:corpus-christian

# --- Web deployment branding & CORS (v0.3.7+, optional) ---
# Unset = no SEO meta exposed, CORS denies all cross-origin (safest default).
# WENJI_SITE_URL=https://wenji.example.com
# WENJI_SITE_NAME=My Wenji
# WENJI_OG_IMAGE_URL=https://wenji.example.com/og.png
# WENJI_CORS_ORIGINS=https://my-frontend.example.com

# --- Production auth (recommended for public deployments) ---
# WENJI_API_KEY=

# --- Hierarchical axes (optional) ---
# WENJI_AXES_YAML=axes.yaml
